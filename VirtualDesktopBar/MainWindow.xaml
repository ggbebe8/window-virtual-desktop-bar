<Window x:Class="VirtualDesktopBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VD Bar" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent" 
        Topmost="True" 
        ShowInTaskbar="False" 
        ResizeMode="NoResize"
        ShowActivated="False"
        SizeToContent="WidthAndHeight">

    <!-- 전체 배경 (반투명 바) -->
    <Border Background="#CC000000" CornerRadius="10" Padding="5" Margin="5">

        <!-- 바깥쪽 루프: 데스크톱 그룹 (1번, 2번...) -->
        <ItemsControl x:Name="DesktopGroups">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- 각 데스크톱 그룹을 구분하는 세로선 (오른쪽 테두리) -->
                    <Border Background="{Binding BackgroundBrush}" BorderBrush="#44FFFFFF" Margin="0,0,5,0" Padding="0,0,5,0" CornerRadius="4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLast}" Value="True">
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">

                            <!-- 🔥 수정된 부분: 데스크톱 번호 클릭 시 이동 기능 추가 🔥 -->
                            <Border Margin="3,0,6,0" Padding="4,2" VerticalAlignment="Center" 
                                    MouseDown="DesktopId_MouseDown" MouseRightButtonDown="DesktopId_MouseRightButtonDown" 
                                    Cursor="Hand" Background="Transparent">
                                <TextBlock Text="{Binding DisplayName}" Foreground="#DDFFFFFF" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <!-- 안쪽 루프: 해당 데스크톱에 속한 앱 아이콘들 -->
                            <ItemsControl ItemsSource="{Binding Apps}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- FocusBrush에 테두리 색상 바인딩 (포커스 시 파란색, 아닐 시 투명) -->
                                        <!-- MouseDown 이벤트 추가 및 커서 변경 -->
                                        <Border Width="28" Height="28" Margin="2" CornerRadius="3" Background="#11FFFFFF"
                                                BorderThickness="2" BorderBrush="{Binding FocusBrush}"
                                                MouseDown="AppIcon_MouseDown" Cursor="Hand">
                                            <Image Source="{Binding AppIcon}" RenderOptions.BitmapScalingMode="HighQuality" Margin="2"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</Window>